# Django Settings
DEBUG=1
SECRET_KEY=django-insecure-vibarr-secret-change-me
ALLOWED_HOSTS=localhost,127.0.0.1,web

# Database Settings
# For Docker: postgres://vibarr:vibarr@db:5432/vibarr
# For Local: sqlite:///db.sqlite3
DATABASE_URL=sqlite:///db.sqlite3

# Docker Database Connection (for entrypoint wait)
DATABASE=postgres
SQL_HOST=db
SQL_PORT=5432
POSTGRES_USER=vibarr
POSTGRES_PASSWORD=vibarr
POSTGRES_DB=vibarr

# Redis Settings
# For Docker: redis://redis:6379/0
# For Local: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Superuser (Optional, for auto-creation)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=adminpass

# Optional
TAUTULLI_URL=
TAUTULLI_API_KEY=
